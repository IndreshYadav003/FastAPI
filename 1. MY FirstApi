from fastapi import FastAPI

app = FastAPI()

@app.get("/")
def home():
    return {"message": "Hello, FastAPI!"}

@app.get("/about")
def about():
    return {"name": "Indresh", "course": "B.Tech CSE"}
@app.get("/student/{id}")
def get_student(id: int):
    return {"student_id": id}
